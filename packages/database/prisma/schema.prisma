generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model analytics_events {
  id                    BigInt               @id @default(autoincrement())
  organization_id       BigInt
  store_id              BigInt
  workplace_id          BigInt?
  camera_id             BigInt?
  event_type_id         BigInt
  rule_id               BigInt?
  started_at            DateTime             @db.Timestamptz(6)
  finished_at           DateTime?            @db.Timestamptz(6)
  severity              String               @default("INFO")
  status                String               @default("NEW")
  confidence            Float?
  duration_ms           BigInt?
  employee_id           BigInt?
  shift_id              BigInt?
  external_order_id     String?
  external_receipt_id   String?
  receipt_id            BigInt?
  sale_session_id       BigInt?
  violation_type_id     BigInt?
  operation_type        String?
  risk_amount           Decimal?             @db.Decimal(18, 2)
  title                 String
  description           String?
  metadata              Json                 @default("{}")
  created_at            DateTime             @default(now()) @db.Timestamptz(6)
  updated_at            DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  processing_session_id BigInt?
  worker_id             BigInt?
  deduplication_key     String?
  received_at           DateTime             @default(now()) @db.Timestamptz(6)
  cameras               cameras?             @relation(fields: [camera_id], references: [id], onUpdate: NoAction)
  employees             employees?           @relation(fields: [employee_id], references: [id], onUpdate: NoAction)
  event_types           event_types          @relation(fields: [event_type_id], references: [id], onUpdate: NoAction)
  organizations         organizations        @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  processing_sessions   processing_sessions? @relation(fields: [processing_session_id], references: [id], onUpdate: NoAction)
  rules                 rules?               @relation(fields: [rule_id], references: [id], onUpdate: NoAction)
  shifts                shifts?              @relation(fields: [shift_id], references: [id], onUpdate: NoAction)
  stores                stores               @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  analytics_workers     analytics_workers?   @relation(fields: [worker_id], references: [id], onUpdate: NoAction)
  workplaces            workplaces?          @relation(fields: [workplace_id], references: [id], onUpdate: NoAction)
  receipts              receipts?            @relation(fields: [receipt_id], references: [id], onUpdate: NoAction)
  sale_sessions         sale_sessions?       @relation(fields: [sale_session_id], references: [id], onUpdate: NoAction)
  violation_types       violation_types?     @relation(fields: [violation_type_id], references: [id], onUpdate: NoAction)
  event_evidence        event_evidence[]
  event_objects         event_objects[]
  event_reviews         event_reviews[]
  event_transcripts     event_transcripts[]
  notifications         notifications[]

  @@index([camera_id, started_at(sort: Desc)], map: "idx_analytics_events_camera_time")
  @@index([metadata], map: "idx_analytics_events_metadata_gin", type: Gin)
  @@index([organization_id, started_at(sort: Desc)], map: "idx_analytics_events_org_time")
  @@index([status, severity, started_at(sort: Desc)], map: "idx_analytics_events_status")
  @@index([store_id, started_at(sort: Desc)], map: "idx_analytics_events_store_time")
  @@index([organization_id, created_at(sort: Desc)], map: "idx_analytics_events_org_created")
  @@index([receipt_id], map: "idx_analytics_events_receipt")
  @@index([sale_session_id], map: "idx_analytics_events_sale_session")
  @@index([violation_type_id], map: "idx_analytics_events_violation_type")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model camera_metrics {
  id                BigInt             @id @default(autoincrement())
  camera_id         BigInt
  recorded_at       DateTime           @default(now()) @db.Timestamptz(6)
  status            String             @default("unknown")
  input_fps         Float?
  processing_fps    Float?
  latency_ms        Float?
  dropped_frames    BigInt?
  reconnect_count   BigInt?
  cpu_percent       Float?
  gpu_percent       Float?
  gpu_memory_mb     Float?
  metadata          Json               @default("{}")
  worker_id         BigInt?
  cameras           cameras            @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  analytics_workers analytics_workers? @relation(fields: [worker_id], references: [id], onUpdate: NoAction)

  @@index([camera_id, recorded_at(sort: Desc)], map: "idx_camera_metrics_camera_time")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model camera_models {
  id                   BigInt         @id @default(autoincrement())
  camera_id            BigInt
  model_version_id     BigInt
  roi_id               BigInt?
  process_fps          Float?
  confidence_threshold Float?
  config               Json           @default("{}")
  is_enabled           Boolean        @default(true)
  cameras              cameras        @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  model_versions       model_versions @relation(fields: [model_version_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  camera_rois          camera_rois?   @relation(fields: [roi_id], references: [id], onUpdate: NoAction)

  @@unique([camera_id, model_version_id, roi_id])
  @@index([camera_id], map: "idx_camera_models_camera")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model camera_rois {
  id                                      BigInt          @id @default(autoincrement())
  camera_id                               BigInt
  roi_type_id                             BigInt
  name                                    String
  shape_type                              String          @default("polygon")
  coordinates                             Json
  is_enabled                              Boolean         @default(true)
  created_at                              DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                              DateTime        @default(now()) @db.Timestamptz(6)
  camera_models                           camera_models[]
  cameras                                 cameras         @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  roi_types                               roi_types       @relation(fields: [roi_type_id], references: [id], onUpdate: NoAction)
  detections                              detections[]
  tracks_tracks_end_roi_idTocamera_rois   tracks[]        @relation("tracks_end_roi_idTocamera_rois")
  tracks_tracks_start_roi_idTocamera_rois tracks[]        @relation("tracks_start_roi_idTocamera_rois")

  @@unique([camera_id, name])
  @@index([camera_id], map: "idx_camera_rois_camera")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model camera_streams {
  id                  BigInt                @id @default(autoincrement())
  camera_id           BigInt
  stream_type         String
  stream_url          String
  subtype             String?
  width               Int?
  height              Int?
  source_fps          Float?
  process_fps         Float?
  transport           String                @default("tcp")
  is_primary          Boolean               @default(false)
  is_enabled          Boolean               @default(true)
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  cameras             cameras               @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  processing_sessions processing_sessions[]

  @@index([camera_id], map: "idx_camera_streams_camera")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model cameras {
  id                        BigInt                     @id @default(autoincrement())
  store_id                  BigInt
  workplace_id              BigInt
  name                      String
  code                      String
  manufacturer              String?
  model                     String?
  nvr_channel               String?
  location_description      String?
  status                    String                     @default("unknown")
  last_online_at            DateTime?                  @db.Timestamptz(6)
  last_frame_at             DateTime?                  @db.Timestamptz(6)
  processing_enabled        Boolean                    @default(true)
  is_active                 Boolean                    @default(true)
  created_at                DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  analytics_events          analytics_events[]
  event_evidence            event_evidence[]
  video_observations        video_observations[]
  camera_metrics            camera_metrics[]
  camera_models             camera_models[]
  camera_rois               camera_rois[]
  camera_streams            camera_streams[]
  stores                    stores                     @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workplaces                workplaces                 @relation(fields: [workplace_id], references: [id], onUpdate: NoAction)
  detections                detections[]
  processing_sessions       processing_sessions[]
  rule_assignments          rule_assignments[]
  tracks                    tracks[]
  worker_camera_assignments worker_camera_assignments?
  eventTranscripts          event_transcripts[]

  @@unique([store_id, code])
  @@index([store_id], map: "idx_cameras_store")
  @@index([workplace_id], map: "idx_cameras_workplace")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model detections {
  id                    BigInt               @id @default(autoincrement())
  camera_id             BigInt
  processing_session_id BigInt?
  model_version_id      BigInt?
  roi_id                BigInt?
  detected_at           DateTime             @db.Timestamptz(6)
  frame_number          BigInt?
  class_name            String
  confidence            Float
  x1                    Float
  y1                    Float
  x2                    Float
  y2                    Float
  track_id              String?
  attributes            Json                 @default("{}")
  cameras               cameras              @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  model_versions        model_versions?      @relation(fields: [model_version_id], references: [id], onUpdate: NoAction)
  processing_sessions   processing_sessions? @relation(fields: [processing_session_id], references: [id], onUpdate: NoAction)
  camera_rois           camera_rois?         @relation(fields: [roi_id], references: [id], onUpdate: NoAction)

  @@index([attributes], map: "idx_detections_attributes_gin", type: Gin)
  @@index([camera_id, detected_at(sort: Desc)], map: "idx_detections_camera_time")
  @@index([processing_session_id, frame_number], map: "idx_detections_session_frame")
}

model employees {
  id               BigInt             @id @default(autoincrement())
  organization_id  BigInt
  external_id      String?
  full_name        String
  role             String             @default("cashier")
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  analytics_events analytics_events[]
  organizations    organizations      @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  event_reviews    event_reviews[]
  receipts         receipts[]
  sale_sessions    sale_sessions[]
  receivings       receivings[]
  shifts           shifts[]

  @@unique([organization_id, external_id])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model event_evidence {
  id                    BigInt                  @id @default(autoincrement())
  event_id              BigInt
  camera_id             BigInt?
  receipt_id            BigInt?
  evidence_type         String
  storage_type          String
  file_path             String
  mime_type             String?
  file_size             BigInt?
  captured_at           DateTime                @db.Timestamptz(6)
  expires_at            DateTime?               @db.Timestamptz(6)
  metadata              Json                    @default("{}")
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  public_url            String?
  availability_status   String                  @default("AVAILABLE")
  video_started_at      DateTime?               @db.Timestamptz(6)
  video_finished_at     DateTime?               @db.Timestamptz(6)
  pre_seconds           Int?
  post_seconds          Int?
  analytics_events      analytics_events        @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  cameras               cameras?                @relation(fields: [camera_id], references: [id], onUpdate: NoAction)
  receipts              receipts?               @relation(fields: [receipt_id], references: [id], onUpdate: NoAction)
  video_observations    video_observations[]
  service_check_results service_check_results[]

  @@index([event_id, captured_at], map: "idx_event_evidence_event")
  @@index([receipt_id], map: "idx_event_evidence_receipt")
  @@index([camera_id, captured_at], map: "idx_event_evidence_camera")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model event_objects {
  id               BigInt           @id @default(autoincrement())
  event_id         BigInt
  object_role      String?
  object_type      String
  track_id         BigInt?
  confidence       Float?
  bbox             Json?
  attributes       Json             @default("{}")
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  analytics_events analytics_events @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  tracks           tracks?          @relation(fields: [track_id], references: [id], onUpdate: NoAction)

  @@index([event_id], map: "idx_event_objects_event")
}

model event_reviews {
  id               BigInt           @id @default(autoincrement())
  event_id         BigInt
  reviewer_id      BigInt?
  decision         String
  comment          String?
  previous_status  String?
  new_status       String?
  reviewed_at      DateTime         @default(now()) @db.Timestamptz(6)
  analytics_events analytics_events @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employees        employees?       @relation(fields: [reviewer_id], references: [id], onUpdate: NoAction)

  @@index([event_id, reviewed_at(sort: Desc)], map: "idx_event_reviews_event")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model event_types {
  id               BigInt             @id @default(autoincrement())
  code             String             @unique
  name             String
  category         String
  default_severity String             @default("INFO")
  description      String?
  analytics_events analytics_events[]
  rules            rules[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model external_events {
  id                BigInt         @id @default(autoincrement())
  source_system     String
  event_type        String
  external_event_id String
  store_id          BigInt?
  workplace_id      BigInt?
  occurred_at       DateTime       @db.Timestamptz(6)
  received_at       DateTime       @default(now()) @db.Timestamptz(6)
  payload           Json
  processing_status String         @default("pending")
  processing_error  String?
