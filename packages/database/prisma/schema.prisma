  workplaces        workplaces?    @relation(fields: [workplace_id], references: [id], onUpdate: NoAction)

  @@unique([source_system, external_event_id])
  @@index([payload], map: "idx_external_events_payload_gin", type: Gin)
  @@index([processing_status, received_at], map: "idx_external_events_status")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model model_versions {
  id                   BigInt          @id @default(autoincrement())
  model_id             BigInt
  version              String
  weights_path         String
  config               Json            @default("{}")
  confidence_threshold Float?
  iou_threshold        Float?
  metrics              Json            @default("{}")
  is_active            Boolean         @default(true)
  created_at           DateTime        @default(now()) @db.Timestamptz(6)
  camera_models        camera_models[]
  detections           detections[]
  models               models          @relation(fields: [model_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([model_id, version])
}

model models {
  id             BigInt           @id @default(autoincrement())
  name           String
  model_type     String
  framework      String
  task_type      String
  description    String?
  created_at     DateTime         @default(now()) @db.Timestamptz(6)
  model_versions model_versions[]

  @@unique([name, model_type])
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model notifications {
  id               BigInt           @id @default(autoincrement())
  event_id         BigInt
  channel          String
  recipient        String
  status           String           @default("PENDING")
  payload          Json             @default("{}")
  created_at       DateTime         @default(now()) @db.Timestamptz(6)
  sent_at          DateTime?        @db.Timestamptz(6)
  acknowledged_at  DateTime?        @db.Timestamptz(6)
  error_message    String?
  attempts         Int              @default(0)
  analytics_events analytics_events @relation(fields: [event_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status, created_at], map: "idx_notifications_status")
}

model organizations {
  id                    BigInt                  @id @default(autoincrement())
  name                  String
  code                  String                  @unique
  timezone              String                  @default("UTC")
  is_active             Boolean                 @default(true)
  created_at            DateTime                @default(now()) @db.Timestamptz(6)
  updated_at            DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  analytics_events      analytics_events[]
  analytics_workers     analytics_workers[]
  audit_logs            audit_logs[]
  employees             employees[]
  external_events       external_events[]
  product_scans         product_scans[]
  receipts              receipts[]
  receipt_items         receipt_items[]
  sale_sessions         sale_sessions[]
  video_observations    video_observations[]
  service_check_results service_check_results[]
  violation_types       violation_types[]
  integration_errors    integration_errors[]
  receivings            receivings[]
  receiving_items       receiving_items[]
  rule_assignments      rule_assignments[]
  stores                stores[]
  users                 users[]
  eventTranscripts      event_transcripts[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model processing_sessions {
  id                 BigInt             @id @default(autoincrement())
  camera_id          BigInt
  stream_id          BigInt?
  worker_name        String
  worker_host        String?
  started_at         DateTime           @default(now()) @db.Timestamptz(6)
  finished_at        DateTime?          @db.Timestamptz(6)
  status             String             @default("running")
  frames_read        BigInt             @default(0)
  frames_processed   BigInt             @default(0)
  frames_dropped     BigInt             @default(0)
  average_fps        Float?
  average_latency_ms Float?
  error_message      String?
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  worker_id          BigInt?
  metadata           Json               @default("{}")
  analytics_events   analytics_events[]
  detections         detections[]
  cameras            cameras            @relation(fields: [camera_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  camera_streams     camera_streams?    @relation(fields: [stream_id], references: [id], onUpdate: NoAction)
  analytics_workers  analytics_workers? @relation(fields: [worker_id], references: [id], onUpdate: NoAction)
  tracks             tracks[]

  @@index([camera_id, started_at(sort: Desc)], map: "idx_processing_sessions_camera_started")
}

model roi_types {
  id          BigInt        @id @default(autoincrement())
  code        String        @unique
  name        String
  camera_rois camera_rois[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model rule_assignments {
  id                BigInt         @id @default(autoincrement())
  rule_id           BigInt
