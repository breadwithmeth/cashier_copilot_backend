  rules             rules          @relation(fields: [rule_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  stores            stores?        @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workplaces        workplaces?    @relation(fields: [workplace_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model rules {
  id               BigInt             @id @default(autoincrement())
  code             String             @unique
  name             String
  event_type_id    BigInt
  rule_type        String
  severity         String             @default("medium")
  conditions       Json               @default("{}")
  settings         Json               @default("{}")
  is_active        Boolean            @default(true)
  created_at       DateTime           @default(now()) @db.Timestamptz(6)
  updated_at       DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  analytics_events analytics_events[]
  rule_assignments rule_assignments[]
  event_types      event_types        @relation(fields: [event_type_id], references: [id], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model shifts {
  id                BigInt             @id @default(autoincrement())
  store_id          BigInt
  workplace_id      BigInt?
  employee_id       BigInt?
  external_shift_id String?
  opened_at         DateTime           @db.Timestamptz(6)
  closed_at         DateTime?          @db.Timestamptz(6)
