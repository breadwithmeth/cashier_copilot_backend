  stores            stores             @relation(fields: [store_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workplaces        workplaces?        @relation(fields: [workplace_id], references: [id], onUpdate: NoAction)

  @@unique([store_id, external_shift_id])
  @@index([employee_id, opened_at(sort: Desc)], map: "idx_shifts_employee_time")
}

model stores {
  id                 BigInt               @id @default(autoincrement())
  organization_id    BigInt
  name               String
  code               String
  city               String?
  address            String?
  is_active          Boolean              @default(true)
  created_at         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at         DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  analytics_events   analytics_events[]
  cameras            cameras[]
  external_events    external_events[]
  product_scans      product_scans[]
  receipts           receipts[]
  receipt_items      receipt_items[]
  sale_sessions      sale_sessions[]
  video_observations video_observations[]
  integration_errors integration_errors[]
  receivings         receivings[]
  receiving_items    receiving_items[]
  rule_assignments   rule_assignments[]
  shifts             shifts[]
  organizations      organizations        @relation(fields: [organization_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  workplaces         workplaces[]
  eventTranscripts   event_transcripts[]

  @@unique([organization_id, code])
  @@index([organization_id], map: "idx_stores_organization")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model tracks {
  id                                           BigInt               @id @default(autoincrement())
  camera_id                                    BigInt
  processing_session_id                        BigInt?
  tracker_track_id                             String
  object_type                                  String
  first_seen_at                                DateTime             @db.Timestamptz(6)
  last_seen_at                                 DateTime             @db.Timestamptz(6)
  max_confidence                               Float?
  duration_ms                                  BigInt?
  start_roi_id                                 BigInt?
  end_roi_id                                   BigInt?
